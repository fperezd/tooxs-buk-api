{
  "name": "tooxs-buk-agent",
  "version": "0.1.0",
  "description": "Agente CLI para consultar y operar BUK mediante lenguaje natural",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/server.js",
    "start:cli": "node src/index.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  }
}
