# =========================
# MODO RECOMENDADO: BUK STARTER (Tooxs)
# =========================

# URL base del BUK Starter (ejemplo: https://buk-starter.tooxs.cl)
BUK_STARTER_BASE_URL=

# Token/API key para autenticar contra BUK Starter
BUK_STARTER_API_TOKEN=

# Header de autenticacion del Starter (Authorization, X-Api-Key, etc.)
BUK_STARTER_AUTH_HEADER=Authorization

# Prefijo del token (Bearer, Token, vacio)
BUK_STARTER_AUTH_SCHEME=Bearer

# Header legado opcional usado por algunas integraciones BUK
BUK_STARTER_LEGACY_AUTH_HEADER=auth_token

# Si es true, envia tambien el token en header legado (ademas del principal)
BUK_STARTER_SEND_LEGACY_AUTH_HEADER=true

# Prefijo de rutas que publica el Starter hacia BUK (opcional)
# Ejemplo: /api/buk
BUK_STARTER_ROUTE_PREFIX=

# Endpoint de salud del Starter (sin prefijo de ruta)
BUK_STARTER_HEALTH_PATH=/health

# =========================
# MODO ALTERNATIVO: DIRECTO A BUK
# (Solo si no usas Starter)
# =========================

# URL base de la API de BUK (ejemplo: https://api.buk.cl)
BUK_BASE_URL=

# Token/API key para autenticación contra BUK
BUK_API_TOKEN=

# Header de auth que usa tu tenant de BUK (Authorization, X-Api-Key, etc.)
BUK_AUTH_HEADER=Authorization

# Prefijo del token (Bearer, Token, vacio)
BUK_AUTH_SCHEME=Bearer

# Timeout para requests HTTP
BUK_TIMEOUT_MS=15000

# =========================
# SERVIDOR API (Render / producción)
# =========================

# Clave secreta para autenticar requests a la API HTTP.
# Enviar en header: X-Api-Key: <valor>  o  Authorization: Bearer <valor>
SERVER_API_KEY=

# URL propia del servidor (usada para keep-alive en producción).
# Si está vacía, no se activa el keep-alive automático.
# Ejemplo: https://tooxs-buk-api.onrender.com
SELF_URL=

# Empleados con restricciones de privacidad contractual.
# Formato JSON: array de objetos con "id" y "requiredNameTokens".
# Ejemplo: [{"id":"fp","requiredNameTokens":["fernando","perez"]}]
PROTECTED_EMPLOYEES=
